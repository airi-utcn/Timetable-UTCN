# Environment variables for UTCN Timetable App
# Copy this file to .env and fill in your values.
# All variables have safe defaults in docker-compose.yml — the ones you MUST
# change for production are ADMIN_PASSWORD and FLASK_SECRET.

# ── Admin / security ─────────────────────────────────────────────────────
# Credentials for the /admin panel (change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password-here

# Flask secret key for sessions
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET=change-this-to-a-random-string

# ── Networking ───────────────────────────────────────────────────────────
# Host port the app is published on (container always listens on 5000)
HOST_PORT=5000

# ── Time zone ────────────────────────────────────────────────────────────
# Used for "today"/date-window filtering and event display times.
TZ=Europe/Bucharest

# ── Calendar fetching ────────────────────────────────────────────────────
# Bounded concurrency for ICS HTTP fetching (thread pool size)
ICS_CONCURRENCY=8
# Max concurrent Playwright browsers for the HTML fallback (memory heavy)
PLAYWRIGHT_CONCURRENCY=6
# Extraction window in days relative to today (recurrence expansion bounds)
EXTRACT_PAST_DAYS=30
EXTRACT_FUTURE_DAYS=240
# Set to 1 to keep an admin-uploaded CSV in the config volume instead of
# syncing the CSV shipped inside the Docker image on startup.
KEEP_VOLUME_CSV=0

# Optional: Playwright user data directory for authenticated calendar fetching
# PLAYWRIGHT_USER_DATA_DIR=/app/playwright_data
# Optional: credentials when the published calendars require login
# PLAYWRIGHT_USERNAME=
# PLAYWRIGHT_PASSWORD=

# ── Gunicorn performance tuning (defaults sized for 32GB/16vCPU VM) ──────
GUNICORN_WORKERS=8
GUNICORN_THREADS=4
GUNICORN_WORKER_CLASS=gthread
GUNICORN_TIMEOUT=180
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=2000
GUNICORN_MAX_REQUESTS_JITTER=200
